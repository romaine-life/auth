{
  "name": "@romaine-life/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Romaine.life central auth service. Hono + Better Auth + Drizzle (Postgres). Issues JWTs; apps verify via JWKS.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "check:static-slot-origins": "node scripts/check-static-slot-origins.mjs",
    "check:signjwt-callsites": "node scripts/check-signjwt-callsites.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
